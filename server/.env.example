# --- Бесплатный вариант (рекомендую для тестового): Groq ---
# Ключ: https://console.groq.com/keys  |  доки: https://console.groq.com/docs/quickstart
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Платный / квотный OpenAI (если нужен именно он) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

AI_PROVIDER=

PORT=3000
HOST=0.0.0.0

# CORS: для dev с телефона в той же Wi‑Fi сети
CORS_ALLOW_LAN=true
# или явно: CLIENT_ORIGIN=http://192.168.1.10:5173
CLIENT_ORIGIN=

SERVE_STATIC=false
