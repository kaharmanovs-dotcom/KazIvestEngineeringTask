# ключ только на сервере, в git не кладём (см. .env.example как шаблон)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

PORT=3000
# для CORS в dev обычно vite: http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# если true — отдаём собранный фронт из client/dist одним процессом
SERVE_STATIC=false
